{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients",
    "SigningKey": "bGlmdGFybXlydWxlcmFjcm9zc29ubHlzdHJpcG92ZXJqb3lwcmlkZXNsaWdodGx5ZXM="
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        }
      },
      "decks-route": {
        "ClusterId": "flashcard-cluster",
        "Match": {
          "Path": "/api/v1/decks/{**catch-all}"
        },
        "AuthorizationPolicy": "Authenticated"
      },
      "flashcards-route": {
        "ClusterId": "flashcard-cluster",
        "Match": {
          "Path": "/api/v1/flashcards/{**catch-all}"
        },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5046"
          }
        }
      },
      "flashcard-cluster": {
        "Destinations": {
          "flashcard-service": {
            "Address": "http://localhost:5266"
          }
        }
      }
    }
  }
}
